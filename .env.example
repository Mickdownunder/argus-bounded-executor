# Absolute path to this ARGUS workspace.
ARGUS_WORKSPACE_ROOT=/absolute/path/to/argus-bounded-executor

# Absolute path to the Operator workspace.
OPERATOR_ROOT=/absolute/path/to/operator-control-plane

# Optional sibling workspaces used for delegation.
JUNE_WORKSPACE_ROOT=/absolute/path/to/june-workspace
ATLAS_WORKSPACE_ROOT=/absolute/path/to/atlas-workspace
